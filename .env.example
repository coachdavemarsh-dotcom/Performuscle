# ============================================================
# PERFORMUSCLE — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Nutritionix (get from https://developer.nutritionix.com)
VITE_NUTRITIONIX_APP_ID=your-app-id
VITE_NUTRITIONIX_APP_KEY=your-app-key

# Stripe
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key   # safe for client
STRIPE_SECRET_KEY=sk_test_your-secret-key                  # server-side ONLY
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret            # from Stripe webhook dashboard

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173         # production: https://yoursite.com
MEAL_PLANNER_URL=http://localhost:5175     # production: https://yoursite.com (same domain via Netlify proxy)

# ── Email (Resend) ────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Performuscle <notifications@yourdomain.com>
APP_URL=http://localhost:5173              # production: https://yoursite.com

# ── AI (Anthropic) ───────────────────────────────────────────
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Lead funnel (GoHighLevel) ─────────────────────────────────
# Optional — fires a webhook when someone submits the meal planner lead form
GHL_WEBHOOK_URL=https://your-ghl-webhook-url
GHL_COACHING_URL=https://yoursite.com/apply  # link in meal plan emails

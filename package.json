{
  "name": "performuscle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "dev:meal-planner": "concurrently \"npm run server\" \"cd meal-planner && npm run dev\"",
    "dev:everything": "concurrently \"npm run dev\" \"npm run server\" \"cd meal-planner && npm run dev\"",
    "install:meal-planner": "cd meal-planner && npm install",
    "landing": "node serve-landing.cjs",
    "build:meal-planner": "cd meal-planner && npm run build",
    "build:netlify": "bash scripts/build-site.sh",
    "start:landing": "npm run build:meal-planner && node serve-landing.cjs",
    "dev:landing": "concurrently \"npm run server\" \"cd meal-planner && npm run dev\" \"node serve-landing.cjs\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@supabase/supabase-js": "^2.39.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.3",
    "resend": "^6.9.4",
    "stripe": "^14.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0"
  }
}

{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*",            "destination": "https://performuscle-production.up.railway.app/api/:path*" },
    { "source": "/structural-balance.html", "destination": "/structural-balance.html" },
    { "source": "/coach-tools.html",        "destination": "/coach-tools.html" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/recipes/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ],
  "crons": [
    {
      "path":     "/api/cron/reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path":     "/api/cron/birthdays",
      "schedule": "0 9 * * *"
    }
  ]
}
